---
import Base from "../layouts/Base.astro";
import { getCollection, render } from "astro:content";

const items = await getCollection("schoengeist");
items.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const rendered = await Promise.all(
  items.map(async (item) => {
    const { Content } = await render(item);
    return { item, Content };
  })
);
---

<Base title="Schoengeist" description="A curated slop-free collection of things I genuinely enjoy.">
  <div class="schoengeist-header">
    <h1>Schoengeist</h1>
    <p>A curated slop-free collection of things I genuinely enjoy.</p>
    <p>A dear person once called me Schoengeist. I didn't like it at first, but now I appreciate it.</p>
  </div>

  {rendered.length > 1 && (
    <button class="shuffle-btn" id="shuffle-btn">Shuffle</button>
  )}

  <div class="schoengeist-feed" id="schoengeist-feed">
    {rendered.map(({ item, Content }, i) => (
      <div class="schoengeist-item" data-index={i} style="display:none">
        {item.data.image ? (
          item.data.url ? (
            <a href={item.data.url} target="_blank" rel="noopener">
              <img data-src={item.data.image} alt={item.data.title} />
            </a>
          ) : (
            <img data-src={item.data.image} alt={item.data.title} />
          )
        ) : item.data.color && (
          item.data.url ? (
            <a href={item.data.url} target="_blank" rel="noopener" class="color-block" style={`background:${item.data.color}`}>
              <span class="color-block-title">{item.data.title}</span>
            </a>
          ) : (
            <div class="color-block" style={`background:${item.data.color}`}>
              <span class="color-block-title">{item.data.title}</span>
            </div>
          )
        )}
        <div class="schoengeist-caption">
          <Content />
        </div>
      </div>
    ))}
  </div>

  <script>
    const items = document.querySelectorAll<HTMLElement>('.schoengeist-item');
    let current = -1;

    function show(index: number) {
      if (current >= 0) items[current].style.display = 'none';
      const item = items[index];
      const img = item.querySelector<HTMLImageElement>('img[data-src]');
      if (img) {
        img.src = img.dataset.src!;
        img.removeAttribute('data-src');
      }
      item.style.display = '';
      current = index;
    }

    show(Math.floor(Math.random() * items.length));

    document.getElementById('shuffle-btn')?.addEventListener('click', () => {
      if (items.length < 2) return;
      let next: number;
      do { next = Math.floor(Math.random() * items.length); } while (next === current);
      show(next);
    });
  </script>
</Base>
