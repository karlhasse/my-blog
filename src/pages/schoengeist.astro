---
import Base from "../layouts/Base.astro";
import { getCollection, render } from "astro:content";

const items = await getCollection("schoengeist");
items.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Deterministic pseudo-random from index for scattered positioning
function scatter(index: number) {
  const seed = ((index + 1) * 7919) % 100;
  const widths = [45, 55, 38, 62, 50, 42, 58, 35, 65, 48];
  const width = widths[index % widths.length];
  const maxOffset = 100 - width;
  const offset = Math.floor((seed / 100) * maxOffset);
  return { width, offset };
}

const rendered = await Promise.all(
  items.map(async (item, i) => {
    const { Content } = await render(item);
    return { item, Content, ...scatter(i) };
  })
);
---

<Base title="Schoengeist" description="A curated slop-free collection of things I genuinely enjoy.">
  <div class="schoengeist-header">
    <h1>Schoengeist</h1>
    <p>A curated slop-free collection of things I genuinely enjoy.</p>
  </div>

  <div class="schoengeist-feed">
    {rendered.map(({ item, Content, width, offset }) => (
      <div class="schoengeist-item" style={`width: ${width}%; margin-left: ${offset}%;`}>
        {item.data.image && (
          item.data.url ? (
            <a href={item.data.url} target="_blank" rel="noopener">
              <img src={item.data.image} alt={item.data.title} loading="lazy" />
            </a>
          ) : (
            <img src={item.data.image} alt={item.data.title} loading="lazy" />
          )
        )}
        <div class="schoengeist-caption">
          <Content />
        </div>
      </div>
    ))}
  </div>
</Base>
