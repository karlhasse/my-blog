---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("thoughts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} description={post.data.description}>
  <article>
    <h1>{post.data.title}</h1>
    <p class="post-date">
      {post.data.date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
      })}
    </p>
    <Content />
  </article>

  <a href="#" class="scroll-top" aria-label="Scroll to top">
    <span class="scroll-top-arrow">↑</span>
    <span class="scroll-top-text">Top</span>
  </a>
</Base>

<style>
  .scroll-top {
    position: fixed;
    bottom: 32px;
    right: 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    text-decoration: none;
    color: #999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .scroll-top.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .scroll-top:hover {
    color: #333;
  }

  .scroll-top-arrow {
    font-size: 18px;
    line-height: 1;
  }

  .scroll-top-text {
    font-size: 11px;
    letter-spacing: 0.05em;
  }
</style>

<script>
  const el = document.querySelector('.scroll-top');
  if (el) {
    window.addEventListener('scroll', () => {
      el.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });

    el.addEventListener('click', (e) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
