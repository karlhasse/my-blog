{
	"compatibility_date": "2026-03-12",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "my-blog",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "imgrundedesign.dev",
			"custom_domain": true,
			"override_existing_dns_record": true
		}
	]
}